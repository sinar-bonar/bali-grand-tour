---

const heroImages = [
  'https://img.rezio.io/cmib1/6d7e09fb-b34d-48be-88f1-37dd5ba447bc/36247cc5-34d3-473f-b354-4d0df3be6eea.png',
  'https://img.rezio.io/cmib1/6d7e09fb-b34d-48be-88f1-37dd5ba447bc/c77234d6-d726-49fe-93d3-0c27c6a980d5.png',
];

const heroTitle = '';
const heroSubtitle = '';
---

<section class="relative w-full overflow-hidden">
  <!-- Hero background with gradient overlay -->
  <div
    class="w-full h-[46.875vw] min-h-[300px] max-h-[600px] flex items-center justify-center text-center flex-col px-[50px] md:px-[80px] bg-cover bg-center bg-[#f4f4f4]"
    style="background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('{heroImages[0]}');"
  >
    {heroTitle && (
      <h1 class="text-white text-[26px] md:text-[40px] font-bold max-w-[1200px] mb-[10px]" style="text-shadow: black 0.1em 0.1em 0.2em;">
        {heroTitle}
      </h1>
    )}
    {heroSubtitle && (
      <p class="text-white text-[18px] md:text-[22px] max-w-[1200px]" style="text-shadow: black 0.1em 0.1em 0.2em;">
        {heroSubtitle}
      </p>
    )}
  </div>
</section>
